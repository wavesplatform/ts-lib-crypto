{
  "name": "@waves/ts-lib-crypto",
  "version": "1.4.4",
  "description": "This library contains all algorithm implementations like signature verification and protocol entries like address used in Waves.",
  "keywords": [
    "waves",
    "crypto",
    "protocol",
    "binary",
    "cryptography",
    "signature"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "postpublish": "git push origin head",
    "build": "ts-node build/build.ts cp src/libs/*.d.ts dist/libs;cp src/libs/*.js dist/libs && npm run build-min",
    "build-min": "webpack --config webpack.config.js",
    "deploy": "cd dist; npm publish;",
    "deploy-beta": "cd dist; npm publish -tag beta;",
    "fix-style": "tslint --fix -c tslint.json '{src,test,usage}/**/*{.ts,.tsx}'",
    "test": "jest",
    "test:debug": "node --inspect node_modules/.bin/jest --runInBand"
  },
  "author": "Yuriy Naydenov",
  "contributors": [
    {
      "email": "siemarell@gmail.com",
      "name": "Sergey Borzov"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wavesplatform/ts-lib-crypto.git"
  },
  "dependencies": {
    "js-sha3": "^0.9.3",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/ncp": "^2.0.1",
    "@types/node": "^24.3.0",
    "@types/node-forge": "^1.3.14",
    "jest": "^30.1.0",
    "ncp": "^2.0.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tslint": "^5.18.0",
    "typescript": "^5.9.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^6.0.1"
  }
}
