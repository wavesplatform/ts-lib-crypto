{
  "name": "@waves/ts-lib-crypto",
  "version": "1.5.1.snapshot.2",
  "description": "This library contains all algorithm implementations like signature verification and protocol entries like address used in Waves.",
  "keywords": [
    "waves",
    "crypto",
    "protocol",
    "binary",
    "cryptography",
    "signature"
  ],
  "main": "dist/cjs/index.cjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "postpublish": "git push origin head",
    "build": "ts-node build/build.ts cp src/libs/*.d.ts dist/libs;cp src/libs/*.js dist/libs && npm run build:cjs && npm run build:esm && npm run build-min",
    "build-min": "webpack --config webpack.config.js --mode=production",
    "deploy": "cd dist; npm publish;",
    "deploy-beta": "cd dist; npm publish -tag beta;",
    "fix-style": "eslint --fix .",
    "test": "vitest run",
    "test:debug": "node --inspect node_modules/.bin/jest --runInBand",
    "build:cjs": "webpack --config webpack.cjs.config.js --mode=production",
    "build:esm": "webpack --config webpack.esm.config.js --mode=production"
  },
  "author": "Yuriy Naydenov",
  "contributors": [
    {
      "email": "siemarell@gmail.com",
      "name": "Sergey Borzov"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wavesplatform/ts-lib-crypto.git"
  },
  "dependencies": {
    "js-sha256": "^0.11.1",
    "js-sha3": "^0.9.3",
    "node-forge": "^1.3.2",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@types/ncp": "^2.0.8",
    "@types/node": "^24.3.0",
    "@types/node-forge": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.35.0",
    "vitest": "^4.0.18",
    "ncp": "^2.0.0",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  },
  "module": "dist/esm/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/cjs/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  }
}
